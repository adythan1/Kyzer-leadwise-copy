VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# App Configuration
VITE_APP_NAME=
VITE_APP_URL=

# Stripe (Pricing page checkout) — publishable key + one Price ID per plan/billing cycle
# Create products/prices in Stripe Dashboard → copy pk_... and price_... IDs
# Use VITE_STRIPE_PUBLISHABLE (Stripe "publishable" / public key). Safe in the browser; never put sk_ secret here.
# Alias: VITE_STRIPE_PUBLISHABLE_KEY (same value; some hosts warn about "KEY" in the name)
VITE_STRIPE_PUBLISHABLE=
VITE_STRIPE_PRICE_STARTER_MONTHLY=
VITE_STRIPE_PRICE_STARTER_ANNUAL=
VITE_STRIPE_PRICE_PRO_MONTHLY=
VITE_STRIPE_PRICE_PRO_ANNUAL=
VITE_STRIPE_PRICE_PREMIUM_MONTHLY=
VITE_STRIPE_PRICE_PREMIUM_ANNUAL=
VITE_STRIPE_PRICE_TEAM_MONTHLY=
VITE_STRIPE_PRICE_TEAM_ANNUAL=
VITE_STRIPE_PRICE_BUSINESS_MONTHLY=
VITE_STRIPE_PRICE_BUSINESS_ANNUAL=

# Features (for development phases)
VITE_ENABLE_CORPORATE=
VITE_ENABLE_CERTIFICATES=
VITE_ENABLE_QUIZZES=